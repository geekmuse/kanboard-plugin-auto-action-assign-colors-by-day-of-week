{
    "name": "kanboard-plugin/assign-colors-by-day-of-week",
    "description": "Kanboard plugin: assign task card colors based on the day of the week of the task's due date",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bradley Campbell",
            "email": "oss-projects+kanboard@bradleyscampbell.net"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kanboard\\Plugin\\AssignColorsByDayOfWeek\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kanboard\\Plugin\\AssignColorsByDayOfWeek\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox tests/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
